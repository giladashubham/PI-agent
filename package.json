{
  "name": "pi-custom-bundle-shubham",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Custom Pi package bundle with extensions and web_fetch",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:smoke": "bash ./tests/smoke.sh",
    "test": "npm run test:unit && npm run test:smoke",
    "test:ci": "npm run typecheck && npm run lint && npm run test"
  },
  "pi": {
    "extensions": [
      "./extensions/core/env-loader.ts",
      "./extensions/core/ui/index.ts",
      "./extensions/modes/plan/index.ts",
      "./extensions/policies/custom-system-prompt.ts",
      "./tools/web-fetch/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "dependencies": {
    "picomatch": "^4.0.3",
    "puppeteer": "^24.41.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.2.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
